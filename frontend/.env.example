# Base URL of the Laravel API, including the /api suffix.
#
# 127.0.0.1 rather than localhost: `php artisan serve` binds IPv4 only, and on
# some machines the browser resolves localhost to ::1 first and the request
# then stalls. http://localhost:8000/api works fine wherever that is not a
# problem.
NUXT_PUBLIC_API_BASE=http://127.0.0.1:8000/api
