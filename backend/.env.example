# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="Todo API"
APP_ENV=local
# Generated locally with `php artisan key:generate` — never commit a real key.
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite by default, so there is no database server to install. The file lives
# at database/database.sqlite — create it with `touch database/database.sqlite`.
DB_CONNECTION=sqlite

# To use MySQL or PostgreSQL instead, switch DB_CONNECTION and fill these in:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=todo
# DB_USERNAME=todo
# DB_PASSWORD=

# ---------------------------------------------------------------------------
# Session / cache / queue
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ---------------------------------------------------------------------------
# Auth (Sanctum bearer tokens) and CORS
# ---------------------------------------------------------------------------
# Origins of the Nuxt SPA that are allowed to call this API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Token lifetime in minutes. Leave empty for tokens that never expire.
SANCTUM_TOKEN_EXPIRATION=

# ---------------------------------------------------------------------------
# Mail — unused by this app, writes to storage/logs.
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
